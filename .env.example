# ──────────────────────────────────────────────────────────
# Summer Shred Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────

# Supabase (required for production) — get from Supabase Dashboard → Settings → API
# Add these to Vercel: Project Settings → Environment Variables
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PostgreSQL connection string (for local dev server + migrations only)
# Supported providers (all free tier available):
#   • Neon          https://neon.tech         (recommended)
#   • Supabase      https://supabase.com
#   • Vercel Postgres  (add via Vercel dashboard → Storage)
#
# Format:  postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# For Supabase on Vercel: use port 6543 (transaction pooler), not 5432
DATABASE_URL=postgresql://user:password@db.xxx.supabase.co:6543/postgres?sslmode=require

# Node environment (set automatically by Vercel in production)
NODE_ENV=development

# Port for local dev server (default: 5000)
PORT=5000
